{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avionics.local/flight-recorder/schemas/comparison.schema.json",
  "title": "Avionics Flight Recorder Comparison Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "baseline",
    "candidate",
    "experiment_id",
    "variants",
    "wall_ms_delta",
    "wall_ms_delta_percent",
    "total_tokens_delta",
    "total_tokens_delta_percent",
    "tool_call_count_delta",
    "diff_lines_delta",
    "tests",
    "success",
    "recommendation"
  ],
  "properties": {
    "baseline": { "type": "string" },
    "candidate": { "type": "string" },
    "experiment_id": { "type": ["string", "null"] },
    "variants": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["run_id", "variant", "success", "eval_passed", "total_tokens", "estimated_total_tokens", "wall_ms", "cost_usd", "tool_call_count", "diff_files", "diff_lines", "features"],
        "properties": {
          "run_id": { "type": "string" },
          "variant": { "type": "string" },
          "success": { "type": "boolean" },
          "eval_passed": { "type": ["boolean", "null"] },
          "total_tokens": { "type": ["integer", "null"] },
          "estimated_total_tokens": { "type": ["integer", "null"] },
          "wall_ms": { "type": "integer" },
          "cost_usd": { "type": ["number", "null"] },
          "tool_call_count": { "type": ["integer", "null"] },
          "diff_files": { "type": "integer" },
          "diff_lines": { "type": "integer" },
          "features": { "type": "object" }
        }
      }
    },
    "wall_ms_delta": { "type": ["integer", "null"] },
    "wall_ms_delta_percent": { "type": ["number", "null"] },
    "total_tokens_delta": { "type": ["integer", "null"] },
    "total_tokens_delta_percent": { "type": ["number", "null"] },
    "tool_call_count_delta": { "type": ["integer", "null"] },
    "diff_lines_delta": { "type": "integer" },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline_passed", "candidate_passed"],
      "properties": {
        "baseline_passed": { "type": ["boolean", "null"] },
        "candidate_passed": { "type": ["boolean", "null"] }
      }
    },
    "success": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline", "candidate"],
      "properties": {
        "baseline": { "type": "boolean" },
        "candidate": { "type": "boolean" }
      }
    },
    "recommendation": { "type": "string" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avionics.local/flight-recorder/schemas/agent-run.schema.json",
  "title": "Avionics Flight Recorder Run Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "experiment_id",
    "agent",
    "agent_version",
    "model",
    "scenario",
    "variant",
    "features",
    "eval",
    "repo_path",
    "commit_sha",
    "prompt_hash",
    "started_at",
    "ended_at",
    "wall_ms",
    "exit_code",
    "success",
    "tests_passed",
    "test_exit_code",
    "test_wall_ms",
    "eval_command",
    "eval_exit_code",
    "eval_passed",
    "eval_wall_ms",
    "eval_test_count",
    "eval_passed_count",
    "eval_failed_count",
    "time_to_first_edit_ms",
    "time_to_first_successful_eval_ms",
    "tool_execution_ms",
    "eval_execution_ms",
    "tool_call_count",
    "tool_calls_by_type",
    "file_read_count",
    "file_write_count",
    "failed_tool_call_count",
    "repeated_tool_call_count",
    "search_to_edit_ratio",
    "test_command_count",
    "input_tokens",
    "cached_input_tokens",
    "output_tokens",
    "reasoning_tokens",
    "tool_result_tokens",
    "total_tokens",
    "estimated_total_tokens",
    "diff_files",
    "diff_added",
    "diff_deleted",
    "production_files_changed",
    "test_files_changed",
    "unrelated_files_changed",
    "cost_usd",
    "cost_per_successful_eval_usd",
    "diff_artifact_path",
    "eval_log_artifact_path",
    "artifacts"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "experiment_id": { "type": ["string", "null"] },
    "agent": { "enum": ["codex", "claude", "copilot"] },
    "agent_version": { "type": ["string", "null"] },
    "model": { "type": ["string", "null"] },
    "scenario": { "type": "string" },
    "variant": { "type": "string" },
    "features": { "type": "object", "additionalProperties": { "type": ["boolean", "string", "number", "null"] } },
    "eval": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "command"],
          "properties": {
            "type": { "type": "string" },
            "command": { "type": "string" }
          }
        }
      ]
    },
    "repo_path": { "type": "string" },
    "commit_sha": { "type": ["string", "null"] },
    "prompt_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": "string", "format": "date-time" },
    "wall_ms": { "type": "integer", "minimum": 0 },
    "exit_code": { "type": "integer" },
    "success": { "type": "boolean" },
    "tests_passed": { "type": ["boolean", "null"] },
    "test_exit_code": { "type": ["integer", "null"] },
    "test_wall_ms": { "type": ["integer", "null"] },
    "eval_command": { "type": ["string", "null"] },
    "eval_exit_code": { "type": ["integer", "null"] },
    "eval_passed": { "type": ["boolean", "null"] },
    "eval_wall_ms": { "type": ["integer", "null"] },
    "eval_test_count": { "type": ["integer", "null"] },
    "eval_passed_count": { "type": ["integer", "null"] },
    "eval_failed_count": { "type": ["integer", "null"] },
    "time_to_first_edit_ms": { "type": ["integer", "null"] },
    "time_to_first_successful_eval_ms": { "type": ["integer", "null"] },
    "tool_execution_ms": { "type": ["integer", "null"] },
    "eval_execution_ms": { "type": ["integer", "null"] },
    "tool_call_count": { "type": ["integer", "null"] },
    "tool_calls_by_type": { "type": "object", "additionalProperties": { "type": "integer" } },
    "file_read_count": { "type": ["integer", "null"] },
    "file_write_count": { "type": ["integer", "null"] },
    "failed_tool_call_count": { "type": ["integer", "null"] },
    "repeated_tool_call_count": { "type": ["integer", "null"] },
    "search_to_edit_ratio": { "type": ["number", "null"] },
    "test_command_count": { "type": "integer", "minimum": 0 },
    "input_tokens": { "type": ["integer", "null"] },
    "cached_input_tokens": { "type": ["integer", "null"] },
    "output_tokens": { "type": ["integer", "null"] },
    "reasoning_tokens": { "type": ["integer", "null"] },
    "tool_result_tokens": { "type": ["integer", "null"] },
    "total_tokens": { "type": ["integer", "null"] },
    "estimated_total_tokens": { "type": ["integer", "null"] },
    "diff_files": { "type": "integer", "minimum": 0 },
    "diff_added": { "type": "integer", "minimum": 0 },
    "diff_deleted": { "type": "integer", "minimum": 0 },
    "production_files_changed": { "type": ["integer", "null"] },
    "test_files_changed": { "type": ["integer", "null"] },
    "unrelated_files_changed": { "type": ["integer", "null"] },
    "cost_usd": { "type": ["number", "null"] },
    "cost_per_successful_eval_usd": { "type": ["number", "null"] },
    "diff_artifact_path": { "type": "string" },
    "eval_log_artifact_path": { "type": "string" },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stdout", "stderr", "raw_events", "diff", "diffstat", "test_log", "eval_log"],
      "properties": {
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "raw_events": { "type": "string" },
        "diff": { "type": "string" },
        "diffstat": { "type": "string" },
        "test_log": { "type": "string" },
        "eval_log": { "type": "string" }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://avionics.local/flight-recorder/schemas/agent-sdlc-event-1.0.schema.json",
  "title": "Avionics Flight Recorder Agent SDLC Event",
  "type": "object",
  "required": ["schema_version", "event_id", "run_id", "timestamp", "type"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "event_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "type": { "enum": ["task", "plan", "context.read", "search", "tool.call", "command", "file.edit", "test", "diff", "review", "cost", "outcome"] },
    "trace_id": { "type": "string" },
    "span_id": { "type": "string" },
    "parent_span_id": { "type": "string" },
    "attributes": { "type": "object", "additionalProperties": { "type": ["boolean", "number", "string", "null"] } },
    "metrics": { "type": "object", "additionalProperties": { "type": ["number", "null"] } },
    "artifact_ref": { "type": "string" }
  },
  "additionalProperties": false
}

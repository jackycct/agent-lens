{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-lens.local/schemas/agent-run.schema.json",
  "title": "AgentLens Run Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "agent",
    "agent_version",
    "model",
    "scenario",
    "variant",
    "repo_path",
    "commit_sha",
    "prompt_hash",
    "started_at",
    "ended_at",
    "wall_ms",
    "exit_code",
    "success",
    "tests_passed",
    "test_exit_code",
    "test_wall_ms",
    "tool_call_count",
    "file_read_count",
    "file_write_count",
    "input_tokens",
    "cached_input_tokens",
    "output_tokens",
    "reasoning_tokens",
    "total_tokens",
    "diff_files",
    "diff_added",
    "diff_deleted",
    "cost_usd",
    "artifacts"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "agent": { "enum": ["codex", "claude", "copilot"] },
    "agent_version": { "type": ["string", "null"] },
    "model": { "type": ["string", "null"] },
    "scenario": { "type": "string" },
    "variant": { "type": "string" },
    "repo_path": { "type": "string" },
    "commit_sha": { "type": ["string", "null"] },
    "prompt_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": "string", "format": "date-time" },
    "wall_ms": { "type": "integer", "minimum": 0 },
    "exit_code": { "type": "integer" },
    "success": { "type": "boolean" },
    "tests_passed": { "type": ["boolean", "null"] },
    "test_exit_code": { "type": ["integer", "null"] },
    "test_wall_ms": { "type": ["integer", "null"] },
    "tool_call_count": { "type": ["integer", "null"] },
    "file_read_count": { "type": ["integer", "null"] },
    "file_write_count": { "type": ["integer", "null"] },
    "input_tokens": { "type": ["integer", "null"] },
    "cached_input_tokens": { "type": ["integer", "null"] },
    "output_tokens": { "type": ["integer", "null"] },
    "reasoning_tokens": { "type": ["integer", "null"] },
    "total_tokens": { "type": ["integer", "null"] },
    "diff_files": { "type": "integer", "minimum": 0 },
    "diff_added": { "type": "integer", "minimum": 0 },
    "diff_deleted": { "type": "integer", "minimum": 0 },
    "cost_usd": { "type": ["number", "null"] },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stdout", "stderr", "raw_events", "diff", "diffstat", "test_log"],
      "properties": {
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "raw_events": { "type": "string" },
        "diff": { "type": "string" },
        "diffstat": { "type": "string" },
        "test_log": { "type": "string" }
      }
    }
  }
}
